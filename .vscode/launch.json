{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Dev Debug",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/server",
      "envFile": "${workspaceFolder}/.env",
      "preLaunchTask": "dev build",
      "cwd": "${workspaceFolder}",
      "console": "internalConsole",
      "internalConsoleOptions": "openOnSessionStart"
    },
    {
      "name": "Prod Debug",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/server",
      "envFile": "${workspaceFolder}/.env",
      "preLaunchTask": "prod build",
      "cwd": "${workspaceFolder}",
      "console": "internalConsole",
      "internalConsoleOptions": "openOnSessionStart"
    },
    { //TODO TEST CONTAINER WORKFLOWS
      "name": "Dev Docker Build and Launch",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "preLaunchTask": "dev docker-compose: up --build",
      "cwd": "${workspaceFolder}",
      "args": [],
      "buildFlags": ""
    },
    {
      "name": "Prod Docker Build and Launch",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "preLaunchTask": "prod docker-compose: up --build",
      "cwd": "${workspaceFolder}",
      "args": [],
      "buildFlags": ""
    },
    {
      "name": "Attach to Delve (container)",
      "type": "go",
      "request": "attach",
      "mode": "remote",
      "remotePath": "/app",
      "port": 40000,
      "host": "127.0.0.1",
      "cwd": "${workspaceFolder}",
      "showLog": true
    }
  ]
}
